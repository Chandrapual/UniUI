{
  "name": "uniui",
  "version": "0.1.0",
  "private": true,
  "description": "Production-ready React design system monorepo.",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "packages/*",
    "playground"
  ],
  "scripts": {
    "clean": "node ./scripts/clean.mjs",
    "dev": "npm run dev --workspace @uniui/playground",
    "build": "npm run build:packages && npm run build:playground",
    "build:packages": "npm run build --workspace @uniui/utils && npm run build --workspace @uniui/hooks && npm run build --workspace @uniui/theme && npm run build --workspace @uniui/core",
    "build:playground": "npm run build --workspace @uniui/playground",
    "typecheck": "tsc --pretty false -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^22.15.14",
    "@types/react": "^19.1.3",
    "@types/react-dom": "^19.1.3",
    "@vitejs/plugin-react": "^5.0.2",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.9.2",
    "vite": "^7.1.4",
    "vite-plugin-dts": "^4.5.4"
  }
}
