{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "types": ["node", "vite/client"]
  },
  "include": [
    "config/**/*.ts",
    "packages/*/src/**/*.ts",
    "packages/*/src/**/*.tsx",
    "packages/*/vite.config.ts",
    "playground/src/**/*.ts",
    "playground/src/**/*.tsx",
    "playground/vite.config.ts"
  ]
}
